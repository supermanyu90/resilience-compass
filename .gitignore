# android/
# ios/

# Never commit the Gemma model weights (large; license-gated)
assets/models/*.litertlm
assets/models/*.task
assets/models/*.bin
assets/models/*.gguf

# Never commit the reference web app (user-provided, may be internal)
reference/resilience-suite/

# Local secrets (HF token, kaggle.json) — must never leave the device/repo
*.env
kaggle.json
